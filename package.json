{
  "name": "ironsharp",
  "private": true,
  "version": "1.0.0",
  "description": "IronSharp — a discipleship devotional app. React Native (Expo) client + Hono/Drizzle API server on Neon + Railway.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "server": "npm run dev --workspace @ironsharp/server",
    "mobile": "npm run start --workspace @ironsharp/mobile",
    "db:push": "npm run db:push --workspace @ironsharp/server",
    "db:seed": "npm run db:seed --workspace @ironsharp/server"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
