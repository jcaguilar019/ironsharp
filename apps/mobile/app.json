{
  "expo": {
    "name": "IronSharp",
    "slug": "ironsharp",
    "scheme": "ironsharp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ironsharp.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "IronSharp uses your photos to set your profile picture.",
        "NSCameraUsageDescription": "IronSharp uses your camera to take a profile photo.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ironsharp.app",
      "permissions": [],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E2A3A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "IronSharp uses your photos to set your profile picture.",
          "cameraPermission": "IronSharp uses your camera to take a profile photo."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "#1E2A3A",
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7d341012-d0a8-4ea6-a4cd-927886fd5927"
      }
    },
    "owner": "josiahturnq",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7d341012-d0a8-4ea6-a4cd-927886fd5927"
    }
  }
}
