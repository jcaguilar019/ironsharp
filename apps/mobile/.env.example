# Base URL of the IronSharp API (the Hono server in apps/server).
#
# Local dev: use your machine's LAN IP, NOT localhost — the app runs on a
# phone/simulator that can't reach your laptop via "localhost".
#   Find it with: ipconfig getifaddr en0   (macOS)  or  hostname -I  (Linux)
#   e.g. EXPO_PUBLIC_API_URL="http://192.168.1.50:8787"
#
# Production: your Railway URL, e.g. https://ironsharp-api.up.railway.app
EXPO_PUBLIC_API_URL="http://localhost:8787"
