# ── Neon Postgres ────────────────────────────────────────────────
# Copy your Neon connection string here (Dashboard → Connection Details).
# Use the *pooled* connection string for the running server.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Neon Auth ────────────────────────────────────────────────────
# Authentication is handled by Neon Auth (managed Better Auth). Enable it in the
# Neon Console → Auth, then copy your project's Auth URL here. The server uses it
# to fetch Neon's public keys ({NEON_AUTH_URL}/.well-known/jwks.json) and verify
# the JWTs the app sends. There is NO auth secret to manage.
# Example: https://ep-xxxx.neonauth.us-east-2.aws.neon.tech/neondb/auth
NEON_AUTH_URL="https://YOUR-PROJECT.neonauth.REGION.aws.neon.tech/neondb/auth"

# ── Server ───────────────────────────────────────────────────────
# Locally the server defaults to 8787. Railway injects PORT automatically.
PORT=8787

# ── Community Devotional admin ───────────────────────────────────
# Admin rights (authoring the daily Community Devotional) come from Neon Auth's
# built-in role system — set a user's role to "admin" in the Neon Console → Auth
# → Users. No env var needed. (The old ADMIN_USER_IDS allowlist was removed.)

# ── api.bible (live passage fallback) ────────────────────────────
# Backs translations not stored in the local DB (e.g. WEB). Server-side only —
# do NOT prefix with EXPO_PUBLIC_, or the key would ship inside the app binary.
# Get a free key at https://docs.api.bible.
BIBLE_API_KEY=""
BIBLE_API_BASE_URL="https://rest.api.bible"

# ── AI providers ─────────────────────────────────────────────────
# Anthropic powers plan generation (POST /api/plans/generate); without it that
# endpoint 500s. OpenAI powers Commute Mode narration (POST /api/tts); without
# it the app falls back to the on-device voice (endpoint returns 503).
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
